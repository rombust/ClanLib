# pkg-config Metadata for clanVK

prefix=@prefix@
exec_prefix=${prefix}
libdir=@libdir@
includedir=${prefix}/include/ClanLib-@LT_RELEASE@

Name: clanVK
Description: Vulkan display target of ClanLib
Version: @VERSION@
Requires: clanDisplay-@LT_RELEASE@ = @VERSION@
Libs:   -L${libdir} -lclan@CLANLIB_RELEASE@GL @extra_LIBS_clanVK@
Cflags: -I${includedir} @extra_CFLAGS_common@ @extra_CFLAGS_clanVK@

# EOF #

